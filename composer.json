{
    "name": "owncloud/openidconnect",
    "type": "library",
    "description": "OpenId Connect app for ownCloud",
    "provide": {
        "phpseclib/phpseclib": "^3.0.36"
    },
    "require": {
        "php": ">=8.3",
        "jumbojett/openid-connect-php": "^1.0.2"
    },
    "require-dev": {
        "bamarni/composer-bin-plugin": "^1.8",
        "roave/security-advisories": "dev-latest"
    },
    "extra": {
        "bamarni-bin": {
            "bin-links": false
        }
    },
    "license": "AGPL",
    "authors": [
        {
            "name": "Thomas Müller",
            "email": "thomas.mueller@tmit.eu"
        }
    ],
    "config" : {
        "optimize-autoloader": true,
        "classmap-authoritative": false,
        "platform": {
            "php": "8.3"
        },
        "allow-plugins": {
            "bamarni/composer-bin-plugin": true
        }
    }
}
